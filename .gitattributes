# Enforce LF endings for source files
*.py text eol=lf
*.pyi text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mako text eol=lf

# Keep binary files untouched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# Shell / batch scripts
*.sh text eol=lf
*.ps1 text eol=crlf

# Windows specific configs may keep CRLF if needed
docker-compose.yml text eol=lf
